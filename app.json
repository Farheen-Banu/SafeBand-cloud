{
  "expo": {
    "name": "women-safety-app",
    "slug": "women-safety-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "womensafetyapp",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.yourname.womensafetyapp",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "This app uses your location to send emergency alerts to the command center.",
        "NSMicrophoneUsageDescription": "This app uses the microphone to detect screams during emergency situations."
      }
    },
    "android": {
      "package": "com.yourname.womensafetyapp",
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "RECORD_AUDIO",
        "BATTERY_STATS",
        "VIBRATE"
      ],
      "adaptiveIcon": {
        "backgroundColor": "#FFF0F5",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/icon.png",
          "imageWidth": 250,
          "resizeMode": "contain",
          "backgroundColor": "#FFF0F5",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}